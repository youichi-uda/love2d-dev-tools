  "love.timer": {
    "prefix": "love-timer",
    "body": [
      "local ${1:timer} = 0",
      "local ${2:interval} = ${3:1}",
      "",
      "-- In love.update(dt):",
      "${1} = ${1} + dt",
      "if ${1} >= ${2} then",
      "\t${1} = ${1} - ${2}",
      "\t$0",
      "end"
    ],
    "description": "Simple timer pattern"
  },
  "love.aabb": {
    "prefix": "love-aabb",
    "body": [
      "local function checkCollision(x1, y1, w1, h1, x2, y2, w2, h2)",
      "\treturn x1 < x2 + w2 and",
      "\t       x2 < x1 + w1 and",
      "\t       y1 < y2 + h2 and",
      "\t       y2 < y1 + h1",
      "end"
    ],
    "description": "AABB collision detection function"
  }
